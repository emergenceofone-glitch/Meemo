{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to user's profile photo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "Note": {
      "title": "Note",
      "description": "A user's private note",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique note ID" },
        "userId": { "type": "string", "description": "ID of the user who owns the note" },
        "content": { "type": "string", "description": "The content of the note" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the note was created" }
      },
      "required": ["userId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User's private notes"
    }
  }
}
